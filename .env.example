# ── NewsAPI ────────────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Airflow ────────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── Data store (resolved inside Docker network) ────────────────────────────────
FOREST_DB_CONN=postgresql+psycopg2://airflow:airflow@postgres/forest
